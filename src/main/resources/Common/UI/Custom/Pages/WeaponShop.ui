// Generated by Hytale UI Builder (https://hytale.ellie.au).
$C = "../Common.ui";
$C.@Container {
  Anchor: (Width: 800, Height: 500);
  Padding: (Full: 0);

  #Title {
    $C.@Title {
      Text: "Shop";
    }
  }

  #Content {
    LayoutMode: CenterMiddle;

    Group {
      Anchor: (Full: 0);
    }

    Group #BulletItem {
      LayoutMode: Top;

      ItemIcon {
        Anchor: (Width: 70, Height: 70);
        Padding: (Full: 20);
        ItemId: "Weapon_Bullet";
      }

      Group {
        Anchor: (Width: 0, Height: 20);
      }

      Label {
        Text: "Bullet 50";
      }

      Label {
        Text: "50$";
      }

      Group {
        Anchor: (Width: 0, Height: 20);
      }

      $C.@TextButton #BuyBullet {
        Anchor: (...@Anchor, Width: 130, Height: 30);
        Text: "Buy";
      }
    }

    Group {
      Anchor: (Width: 20, Height: 0);
    }

    Group #RifleItem {
      LayoutMode: Top;

      ItemIcon {
        Anchor: (Width: 70, Height: 70);
        Padding: (Full: 20);
        ItemId: "Weapon_Assault_Rifle";
      }

      Group {
        Anchor: (Width: 0, Height: 20);
      }

      Label {
        Text: "Rifle";
      }

      Label {
        Text: "1000$";
      }

      Group {
        Anchor: (Width: 0, Height: 20);
      }

      $C.@TextButton #BuyRifle {
        Anchor: (...@Anchor, Width: 130, Height: 30);
        Text: "Buy";
        Disabled: false;
      }
    }
  }
}